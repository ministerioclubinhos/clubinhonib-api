ENVIRONMENT=staging

# Database Configuration - RDS AWS
DB_HOST=your-rds-host.region.rds.amazonaws.com
DB_PORT=3306
DB_USERNAME=admin
DB_PASSWORD=your-secure-password
DB_NAME=clubinho-nib-staging

# AWS Configuration - Uso geral da aplicação (S3, SES). Credenciais de deploy/LB ficam só no GitHub Secrets.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-app-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-app-aws-secret-access-key
AWS_S3_BUCKET_NAME=clubinho-nib-storage

# Email Configuration (SES)
SES_DEFAULT_FROM=no-reply@yourdomain.com
SES_DEFAULT_TO=admin@yourdomain.com

# JWT Configuration
JWT_SECRET=your-jwt-secret
JWT_REFRESH_SECRET=your-refresh-secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Twilio Configuration
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+1234567890
TWILIO_WHATSAPP_TO=whatsapp:+1234567890

# Feed Configuration
FEED_CLUBINHO_PAGE_ID=your-page-id

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id

# Domain Configuration
DOMAIN_NAME=clubinhonib.com
